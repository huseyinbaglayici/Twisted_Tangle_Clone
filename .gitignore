# -------------------------------
# Unity generated files
# -------------------------------
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
UserSettings/

# MemoryCaptures and Recordings
MemoryCaptures/
Recordings/

# Autogenerated Asset Store tools plugin
Assets/AssetStoreTools*

# Unity generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity crash reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Packed Addressables
Assets/AddressableAssetsData/*/*.bin*

# Temporary auto-generated Android Assets
Assets/StreamingAssets/aa.meta
Assets/StreamingAssets/aa/*

# -------------------------------
# Secrets / API keys (NEVER commit)
# -------------------------------
# Any AI provider API key belongs in an environment variable, never in a committed file.
# These patterns are a safety net so a stray local key file can never be committed.
.env
*.env
**/secrets.json
**/*.secret
**/anthropic*.key

# -------------------------------
# IDE files
# -------------------------------
# JetBrains Rider / IntelliJ
.idea/
*.sublime-workspace
*.sublime-project

# Visual Studio
.vs/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Gradle cache directory
.gradle/

# Other autogenerated editor files
ExportedObj/
.consulo/
*.pidb
*.pdb
*.mdb
*.opendb
